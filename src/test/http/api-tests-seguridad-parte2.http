### ============================================================
### API TESTS COMPLETOS - Seguridad Parte 2 / Multi-tenant
### Compatible con VS Code + extensión REST Client
###
### Instrucciones:
### 1) Levantá la app: ./mvnw spring-boot:run
### 2) Ejecutá las requests EN ORDEN.
### 3) Con spring.jpa.hibernate.ddl-auto=create-drop, los datos se reinician al arrancar.
### 4) El seeder crea estas profesionales:
###    ana.lopez@estetica.local / Password123!
###    maria.gonzalez@estetica.local / Password123!
### ============================================================

@host = http://localhost:8080
@password = Password123!
@fechaTurnoLibre = 2030-01-15T10:00:00
@fechaTurnoSesion = 2030-01-16T10:00:00
@fechaBloqueada = 2030-02-01T15:00:00

### ============================================================
### 0. AUTH
### ============================================================

### 0.1 Login Ana
# @name loginAna
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "ana.lopez@estetica.local",
  "password": "{{password}}"
}

### 0.2 Login María
# @name loginMaria
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "maria.gonzalez@estetica.local",
  "password": "{{password}}"
}

### 0.3 Login incorrecto - debe devolver 401
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "ana.lopez@estetica.local",
  "password": "incorrecta"
}

### 0.4 Endpoint protegido sin token - debe devolver 401
GET {{host}}/api/profesionales/me


### ============================================================
### 1. PERFIL PROFESIONAL AUTENTICADA
### ============================================================

### 1.1 Ver mi perfil como Ana
GET {{host}}/api/profesionales/me
Authorization: Bearer {{loginAna.response.body.$.token}}

### 1.2 Actualizar mi perfil como Ana
PUT {{host}}/api/profesionales/me
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Ana",
  "apellido": "López",
  "email": "ana.lopez@estetica.local",
  "telefono": "1123456789",
  "especialidad": "Cosmetología facial y corporal"
}


### ============================================================
### 2. SERVICIOS DE ANA
### ============================================================

### 2.1 Crear servicio Botox
# @name crearServicioAna1
POST {{host}}/api/servicios
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Botox",
  "descripcion": "Aplicación estética facial",
  "precio": 50000.00
}

### 2.2 Crear servicio Limpieza facial
# @name crearServicioAna2
POST {{host}}/api/servicios
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Limpieza facial profunda",
  "descripcion": "Limpieza con extracción e hidratación",
  "precio": 30000.00
}

### 2.3 Listar servicios de Ana
GET {{host}}/api/servicios
Authorization: Bearer {{loginAna.response.body.$.token}}

### 2.4 Listar servicios activos de Ana
GET {{host}}/api/servicios/activos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 2.5 Buscar servicio de Ana por ID
GET {{host}}/api/servicios/{{crearServicioAna1.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}

### 2.6 Actualizar precio
PATCH {{host}}/api/servicios/{{crearServicioAna1.response.body.$.id}}/precio?nuevoPrecio=60000.00
Authorization: Bearer {{loginAna.response.body.$.token}}

### 2.7 Desactivar servicio 2
PATCH {{host}}/api/servicios/{{crearServicioAna2.response.body.$.id}}/estado?activo=false
Authorization: Bearer {{loginAna.response.body.$.token}}

### 2.8 Reactivar servicio 2
PATCH {{host}}/api/servicios/{{crearServicioAna2.response.body.$.id}}/estado?activo=true
Authorization: Bearer {{loginAna.response.body.$.token}}

### 2.9 Servicio duplicado - debe devolver 400
POST {{host}}/api/servicios
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Botox",
  "descripcion": "Duplicado",
  "precio": 10000.00
}


### ============================================================
### 3. PACIENTES DE ANA
### ============================================================

### 3.1 Crear paciente Laura
# @name crearPacienteAna
POST {{host}}/api/pacientes
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Laura",
  "apellido": "Martínez",
  "dniCuit": "30123456",
  "fechaNacimiento": "1990-05-15",
  "telefono": "3519876543",
  "email": "laura@gmail.com",
  "profesion": "Contadora",
  "domicilio": "Av. Colón 1234",
  "obraSocial": "OSDE",
  "numeroObraSocial": "12345678",
  "contactoEmergenciaNombre": "Carlos Martínez",
  "contactoEmergenciaTelefono": "3511111111",
  "contactoEmergenciaParentesco": "Esposo",
  "entidadTraslado1": "Hospital Privado",
  "entidadTraslado2": "Sanatorio Allende"
}

### 3.2 Listar pacientes de Ana
GET {{host}}/api/pacientes
Authorization: Bearer {{loginAna.response.body.$.token}}

### 3.3 Buscar paciente de Ana por ID
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}

### 3.4 Actualizar paciente
PUT {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Laura",
  "apellido": "Martínez López",
  "dniCuit": "30123456",
  "fechaNacimiento": "1990-05-15",
  "telefono": "3519876543",
  "email": "laura.lopez@gmail.com"
}

### 3.5 Archivar paciente
PATCH {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/estado?activo=false
Authorization: Bearer {{loginAna.response.body.$.token}}

### 3.6 Reactivar paciente
PATCH {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/estado?activo=true
Authorization: Bearer {{loginAna.response.body.$.token}}

### 3.7 DNI duplicado - debe devolver 400
POST {{host}}/api/pacientes
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "nombre": "Otra",
  "apellido": "Persona",
  "dniCuit": "30123456",
  "telefono": "3512222222"
}


### ============================================================
### 4. HISTORIAS CLÍNICAS DE LA PACIENTE DE ANA
### ============================================================

### 4.1 Crear historia clínica facial
# @name crearHCFacialAna
POST {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/historia-clinica-facial
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "hta": false,
  "dbt": false,
  "tbq": false,
  "alcohol": false,
  "fototipoFitzpatrick": 3,
  "gradoGlogau": 2,
  "diagnosticoYTratamiento": "Piel mixta. Limpieza profunda mensual."
}

### 4.2 Obtener historia facial
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/historia-clinica-facial
Authorization: Bearer {{loginAna.response.body.$.token}}

### 4.3 Actualizar historia facial
PUT {{host}}/api/historia-clinica-facial/{{crearHCFacialAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "hta": false,
  "dbt": false,
  "tbq": false,
  "alcohol": false,
  "fototipoFitzpatrick": 3,
  "gradoGlogau": 2,
  "diagnosticoYTratamiento": "Piel mixta. Se agrega mesoterapia.",
  "observacionesPosteriores": "Buena tolerancia."
}

### 4.4 Crear historia clínica corporal
# @name crearHCCorporalAna
POST {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/historia-clinica-corporal
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "hta": false,
  "dbt": false,
  "cancer": false,
  "alimentacionSaludable": true,
  "bebeAgua": true,
  "pesoActual": 65.5,
  "pesoHabitual": 64.0,
  "imc": 23.5,
  "perimetroCintura": 72.0,
  "diagnosticoYTratamiento": "Tratamiento corporal progresivo."
}

### 4.5 Obtener historia corporal
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/historia-clinica-corporal
Authorization: Bearer {{loginAna.response.body.$.token}}


### ============================================================
### 5. TURNOS DE ANA
### ============================================================

### 5.1 Crear turno libre con dos servicios
# @name crearTurnoAna
POST {{host}}/api/turnos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "pacienteId": "{{crearPacienteAna.response.body.$.id}}",
  "fechaHora": "{{fechaTurnoLibre}}",
  "servicioIds": [
    "{{crearServicioAna1.response.body.$.id}}",
    "{{crearServicioAna2.response.body.$.id}}"
  ],
  "observaciones": "Turno con dos servicios"
}

### 5.2 Crear segundo turno para sesión clínica
# @name crearTurnoSesionAna
POST {{host}}/api/turnos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "pacienteId": "{{crearPacienteAna.response.body.$.id}}",
  "fechaHora": "{{fechaTurnoSesion}}",
  "servicioIds": ["{{crearServicioAna1.response.body.$.id}}"],
  "observaciones": "Turno para registrar sesión"
}

### 5.3 Listar turnos de Ana
GET {{host}}/api/turnos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 5.4 Filtrar turnos por estado
GET {{host}}/api/turnos?estado=PENDIENTE
Authorization: Bearer {{loginAna.response.body.$.token}}

### 5.5 Filtrar turnos por rango
GET {{host}}/api/turnos?desde=2030-01-01T00:00:00&hasta=2030-01-31T23:59:59
Authorization: Bearer {{loginAna.response.body.$.token}}

### 5.6 Buscar turno por ID
GET {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}

### 5.7 Listar turnos del paciente
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/turnos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 5.8 Confirmar turno de sesión
PATCH {{host}}/api/turnos/{{crearTurnoSesionAna.response.body.$.id}}/estado?nuevoEstado=CONFIRMADO
Authorization: Bearer {{loginAna.response.body.$.token}}

### 5.9 Marcar turno de sesión como realizado
PATCH {{host}}/api/turnos/{{crearTurnoSesionAna.response.body.$.id}}/estado?nuevoEstado=REALIZADO
Authorization: Bearer {{loginAna.response.body.$.token}}


### ============================================================
### 6. PAGOS DE ANA
### ============================================================

### 6.1 Registrar pago parcial en efectivo
# @name crearPagoAna
POST {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "metodo": "EFECTIVO",
  "monto": 30000.00,
  "esSena": true
}

### 6.2 Registrar segundo pago por transferencia
POST {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "metodo": "TRANSFERENCIA",
  "monto": 60000.00
}

### 6.3 Listar pagos del turno
GET {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 6.4 Resumen de pagos del turno
GET {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos/resumen
Authorization: Bearer {{loginAna.response.body.$.token}}

### 6.5 Listar pagos de Ana
GET {{host}}/api/pagos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 6.6 Trueque sin detalle - debe devolver 400
POST {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "metodo": "TRUEQUE",
  "monto": 1000.00
}

### 6.7 Pago que supera monto total - debe devolver 400
POST {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "metodo": "EFECTIVO",
  "monto": 999999.00
}

### 6.8 Eliminar pago de turno no realizado
DELETE {{host}}/api/pagos/{{crearPagoAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}


### ============================================================
### 7. SESIÓN CLÍNICA Y FOTOS
### ============================================================

### 7.1 Crear sesión clínica para turno REALIZADO
# @name crearSesionAna
POST {{host}}/api/turnos/{{crearTurnoSesionAna.response.body.$.id}}/sesion-clinica
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "tratamiento": "Aplicación de botox en zona frontal",
  "respuestaTolerancia": "Buena tolerancia, sin molestias relevantes",
  "observaciones": "Control en 15 días"
}

### 7.2 Obtener sesión por turno
GET {{host}}/api/turnos/{{crearTurnoSesionAna.response.body.$.id}}/sesion-clinica
Authorization: Bearer {{loginAna.response.body.$.token}}

### 7.3 Listar sesiones clínicas del paciente
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/sesiones-clinicas
Authorization: Bearer {{loginAna.response.body.$.token}}

### 7.4 Actualizar sesión clínica
PUT {{host}}/api/sesiones-clinicas/{{crearSesionAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "tratamiento": "Aplicación de botox en zona frontal y periocular",
  "respuestaTolerancia": "Muy buena tolerancia",
  "observaciones": "Control en 15 días"
}

### 7.5 Registrar foto
# @name crearFotoAna
POST {{host}}/api/sesiones-clinicas/{{crearSesionAna.response.body.$.id}}/fotos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "sesionClinicaId": "{{crearSesionAna.response.body.$.id}}",
  "descripcion": "Foto antes del control"
}

### 7.6 Listar fotos del paciente
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/fotos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 7.7 Listar fotos de la sesión
GET {{host}}/api/sesiones-clinicas/{{crearSesionAna.response.body.$.id}}/fotos
Authorization: Bearer {{loginAna.response.body.$.token}}

### 7.8 Eliminar foto
DELETE {{host}}/api/fotos/{{crearFotoAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}


### ============================================================
### 8. BLOQUEOS DE AGENDA
### ============================================================

### 8.1 Crear bloqueo válido
# @name crearBloqueoAna
POST {{host}}/api/bloqueos-agenda
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "fechaInicio": "2030-02-01T14:00:00",
  "fechaFin": "2030-02-01T16:00:00",
  "motivo": "Capacitación"
}

### 8.2 Listar bloqueos de Ana
GET {{host}}/api/bloqueos-agenda
Authorization: Bearer {{loginAna.response.body.$.token}}

### 8.3 Buscar bloqueo por ID
GET {{host}}/api/bloqueos-agenda/{{crearBloqueoAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}

### 8.4 Crear turno en fecha bloqueada - debe devolver 400 mencionando motivo
POST {{host}}/api/turnos
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "pacienteId": "{{crearPacienteAna.response.body.$.id}}",
  "fechaHora": "{{fechaBloqueada}}",
  "servicioIds": ["{{crearServicioAna1.response.body.$.id}}"],
  "observaciones": "Debe fallar por bloqueo"
}

### 8.5 Crear bloqueo solapado - debe devolver 400
POST {{host}}/api/bloqueos-agenda
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "fechaInicio": "2030-02-01T15:30:00",
  "fechaFin": "2030-02-01T17:00:00",
  "motivo": "Solapado"
}

### 8.6 Actualizar bloqueo
PUT {{host}}/api/bloqueos-agenda/{{crearBloqueoAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}
Content-Type: application/json

{
  "fechaInicio": "2030-02-01T14:00:00",
  "fechaFin": "2030-02-01T16:30:00",
  "motivo": "Capacitación extendida"
}

### 8.7 Eliminar bloqueo
DELETE {{host}}/api/bloqueos-agenda/{{crearBloqueoAna.response.body.$.id}}
Authorization: Bearer {{loginAna.response.body.$.token}}


### ============================================================
### 9. AISLAMIENTO MULTI-TENANT: MARÍA NO VE LO DE ANA
### Todos estos casos deben devolver 404 por diseño, para no revelar existencia.
### ============================================================

### 9.1 María lista sus servicios: no debe aparecer Botox de Ana
GET {{host}}/api/servicios
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.2 María intenta ver servicio de Ana - debe devolver 404
GET {{host}}/api/servicios/{{crearServicioAna1.response.body.$.id}}
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.3 María intenta modificar precio de servicio de Ana - debe devolver 404
PATCH {{host}}/api/servicios/{{crearServicioAna1.response.body.$.id}}/precio?nuevoPrecio=1.00
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.4 María lista sus pacientes: no debe aparecer Laura
GET {{host}}/api/pacientes
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.5 María intenta ver paciente de Ana - debe devolver 404
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.6 María intenta ver historia facial de paciente de Ana - debe devolver 404
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/historia-clinica-facial
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.7 María intenta ver turno de Ana - debe devolver 404
GET {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.8 María intenta listar pagos del turno de Ana - debe devolver 404
GET {{host}}/api/turnos/{{crearTurnoAna.response.body.$.id}}/pagos
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.9 María intenta ver sesión clínica de turno de Ana - debe devolver 404
GET {{host}}/api/turnos/{{crearTurnoSesionAna.response.body.$.id}}/sesion-clinica
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.10 María intenta listar fotos del paciente de Ana - debe devolver 404
GET {{host}}/api/pacientes/{{crearPacienteAna.response.body.$.id}}/fotos
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.11 María lista sus turnos: no debe aparecer ningún turno de Ana
GET {{host}}/api/turnos
Authorization: Bearer {{loginMaria.response.body.$.token}}

### 9.12 María lista sus pagos: no debe aparecer ningún pago de Ana
GET {{host}}/api/pagos
Authorization: Bearer {{loginMaria.response.body.$.token}}

