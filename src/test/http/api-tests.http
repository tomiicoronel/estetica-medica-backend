### ============================================================
### Variables base
### ============================================================
@host = http://localhost:8080

### ============================================================
### 1. PROFESIONAL
### ============================================================

### 1.1 Crear profesional — 201 Created
# @name crearProfesional
POST {{host}}/api/profesionales
Content-Type: application/json

{
  "nombre": "María",
  "apellido": "González",
  "email": "maria.gonzalez@estetica.com",
  "telefono": "3514567890",
  "especialidad": "Estética facial"
}

###

@profesionalId = {{crearProfesional.response.body.id}}

### 1.2 Listar todas las profesionales — 200 OK
GET {{host}}/api/profesionales

### 1.3 Buscar profesional por ID — 200 OK
GET {{host}}/api/profesionales/{{profesionalId}}

### 1.4 Actualizar profesional — 200 OK
PUT {{host}}/api/profesionales/{{profesionalId}}
Content-Type: application/json

{
  "nombre": "María",
  "apellido": "González López",
  "email": "maria.gonzalez@estetica.com",
  "telefono": "3514567890",
  "especialidad": "Estética facial y corporal"
}

### 1.5 Crear profesional con email duplicado — 400 Bad Request
POST {{host}}/api/profesionales
Content-Type: application/json

{
  "nombre": "Otra",
  "apellido": "Persona",
  "email": "maria.gonzalez@estetica.com",
  "telefono": "3514000000",
  "especialidad": "Test"
}

### 1.6 Crear profesional sin email — 400 Bad Request (validación)
POST {{host}}/api/profesionales
Content-Type: application/json

{
  "nombre": "Sin",
  "apellido": "Email",
  "telefono": "3514000000",
  "especialidad": "Test"
}

### 1.7 Buscar profesional inexistente — 404 Not Found
GET {{host}}/api/profesionales/00000000-0000-0000-0000-000000000000

### ============================================================
### 2. SERVICIO
### ============================================================

### 2.1 Crear servicio — 201 Created
# @name crearServicio
POST {{host}}/api/profesionales/{{profesionalId}}/servicios
Content-Type: application/json

{
  "profesionalId": "{{profesionalId}}",
  "nombre": "Limpieza facial profunda",
  "descripcion": "Tratamiento completo de limpieza con extracción",
  "precio": 30000.00
}

###

@servicioId = {{crearServicio.response.body.id}}

### 2.2 Crear segundo servicio — 201 Created
# @name crearServicio2
POST {{host}}/api/profesionales/{{profesionalId}}/servicios
Content-Type: application/json

{
  "profesionalId": "{{profesionalId}}",
  "nombre": "Mesoterapia facial",
  "descripcion": "Aplicación de vitaminas y antioxidantes",
  "precio": 25000.00
}

###

@servicioId2 = {{crearServicio2.response.body.id}}

### 2.3 Listar servicios de la profesional — 200 OK
GET {{host}}/api/profesionales/{{profesionalId}}/servicios

### 2.4 Buscar servicio por ID — 200 OK
GET {{host}}/api/servicios/{{servicioId}}

### 2.5 Actualizar precio (PATCH) — 200 OK
PATCH {{host}}/api/servicios/{{servicioId}}/precio?nuevoPrecio=35000.00

### 2.6 Cambiar estado a inactivo — 200 OK
PATCH {{host}}/api/servicios/{{servicioId2}}/estado?activo=false

### 2.7 Listar solo activos — 200 OK
GET {{host}}/api/profesionales/{{profesionalId}}/servicios/activos

### 2.8 Reactivar servicio — 200 OK
PATCH {{host}}/api/servicios/{{servicioId2}}/estado?activo=true

### 2.9 Crear servicio con nombre duplicado — 400 Bad Request
POST {{host}}/api/profesionales/{{profesionalId}}/servicios
Content-Type: application/json

{
  "profesionalId": "{{profesionalId}}",
  "nombre": "Limpieza facial profunda",
  "descripcion": "Otro",
  "precio": 10000.00
}

